            }

            table-row-1 := Rectangle {
                width: 738px;
                height: 30px;
                x: 0px;
                y: 30px;
                background: #45474aff;
                clip: true;

                Text { width: 107px; height: 16px; x: 304px; y: 7px; text: "Yesterday, 10:00 AM"; font-family: "Segoe UI"; font-size: 12px; color: #ebf1ffff; horizontal-alignment: center; vertical-alignment: center; }
                Text { width: 99px; height: 16px; x: 483px; y: 7px; text: "~\\Documents\\veal"; font-family: "Segoe UI"; font-size: 12px; color: #ebf1ffff; horizontal-alignment: center; vertical-alignment: center; }
                Text { width: 72px; height: 16px; x: 8px; y: 7px; text: "Project Name"; font-family: "Segoe UI"; font-size: 12px; color: #ebf1ffff; horizontal-alignment: center; vertical-alignment: center; }

                Rectangle { width: 1px; height: 15px; x: 288px; y: 8px; background: #76777bff; }
                Rectangle { width: 1px; height: 15px; x: 467px; y: 7px; background: #76777bff; }
            }

            table-row-2 := Rectangle {
                width: 738px;
                height: 30px;
                x: 0px;
                y: 60px;
                background: #5d5e62ff;
                clip: true;

                Text { width: 107px; height: 16px; x: 304px; y: 7px; text: "Yesterday, 10:00 AM"; font-family: "Segoe UI"; font-size: 12px; color: #ebf1ffff; horizontal-alignment: center; vertical-alignment: center; }
                Text { width: 99px; height: 16px; x: 483px; y: 7px; text: "~\\Documents\\veal"; font-family: "Segoe UI"; font-size: 12px; color: #ebf1ffff; horizontal-alignment: center; vertical-alignment: center; }
                Text { width: 72px; height: 16px; x: 8px; y: 7px; text: "Project Name"; font-family: "Segoe UI"; font-size: 12px; color: #ebf1ffff; horizontal-alignment: center; vertical-alignment: center; }

                Rectangle { width: 1px; height: 15px; x: 288px; y: 8px; background: #76777bff; }
                Rectangle { width: 1px; height: 15px; x: 467px; y: 7px; background: #76777bff; }
